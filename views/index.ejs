<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SM WEB | Criação de landing pages, e instalação de chatbots</title>
    <meta
      name="description"
      content="A smweb cria landing pages e instala chatbots para ajudar empresas a vender mais, responder mais rápido e organizar o primeiro atendimento."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="icon" href="/assets/img/favico.ico" type="image/x-icon">
  </head>
  <body>
    <header class="site-header" id="topo">
      <div class="container nav-wrapper">
        <a class="brand" href="#topo" aria-label="Ir para o topo">
          <img id="logo-header" src="/assets/img/logo-1.webp" alt="Logo da smweb">
        </a>

        <button
          class="menu-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="site-menu"
        >
          <span></span>
          <span></span>
          <span></span>
          <span class="sr-only">Abrir menu</span>
        </button>

        <nav class="site-nav" id="site-menu" aria-label="Navegação principal">
          <a href="#servicos">Serviços</a>
          <a href="#diferenciais">Diferenciais</a>
          <a href="#processo">Processo</a>
          <a
            href="https://blog.smweb.com.br"
          >Blog</a>
          <a href="#contato" class="nav-cta">Falar sobre o projeto</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="container hero-grid">
          <div class="hero-copy">
            <div class="hero-copy-inner">
              <p class="eyebrow">Landing pages com foco comercial</p>
              <h1>
                Landing Pages de Alta Conversão com Chatbots para Automatizar seu Atendimento
              </h1>
              <div class="hero-visual">
                <img src="/assets/img/img1.webp" alt="Ilustração da proposta da smweb" decoding="async" />
              </div>
              <p class="hero-text">
                Estrutura simples, mensagem clara e automação prática para negócios
                que precisam captar leads, responder rápido e tirar ideias do papel.
              </p>
              <div class="hero-actions">
                <a class="button button-primary" href="#contato">Quero lançar meu site</a>
                <a class="button button-secondary" href="#servicos">Ver serviços</a>
              </div>
            </div>
          </div>

          <div class="hero-panel" aria-label="Resumo da proposta da smweb">
            <div class="panel-card panel-card-lg">
              <span class="panel-label">Estrutura inicial</span>
              <strong>Homepage clara, rápida e pronta para evoluir</strong>
              <p>
                Base em HTML, CSS e JavaScript puro para começar sem complexidade
                desnecessária.
              </p>
            </div>

            <div class="panel-grid">
              <article class="panel-card">
                <span class="panel-label">Landing pages</span>
                <strong>Oferta mais objetiva</strong>
                <p>Seções organizadas para explicar, convencer e direcionar a ação.</p>
              </article>
              <article class="panel-card">
                <span class="panel-label">Chatbots</span>
                <strong>Atendimento mais ágil</strong>
                <p>Fluxos simples para captar, qualificar e encaminhar contatos.</p>
              </article>
            </div>
          </div>
        </div>
      </section>

      <section class="section" id="servicos">
        <div class="container">
          <div class="section-heading">
            <p class="eyebrow">O que a smweb faz</p>
            <h2>Nossos serviços</h2>
            <p>
              Uma base comercial enxuta para empresas que querem melhorar presença
              digital e organizar o contato com novos clientes.
            </p>
          </div>

          <div class="services-grid">
            <article class="service-card">
              <span class="card-index">01</span>
              <h3>Landing pages</h3>
              <img src="/assets/img/sm2.webp" alt="">
              <p>
                Páginas de venda, apresentação de serviço e captação de leads com
                estrutura direta, responsiva e pronta para crescer com o negócio.
              </p>
              <ul class="feature-list">
                <li>Headline e proposta de valor mais claras</li>
                <li>Seções com foco em conversão</li>
                <li>Base fácil de manter e editar</li>
              </ul>
            </article>

            <article class="service-card service-card-accent">
              <span class="card-index">02</span>
              <h3>Instalação de chatbots</h3>
              <img src="/assets/img/sm3.webp" alt="">
              <p>
                Implementação de atendimento automatizado para acelerar respostas,
                filtrar demandas e manter o contato ativo desde o primeiro clique.
              </p>
              <ul class="feature-list">
                <li>Coleta inicial de informações do lead</li>
                <li>Organização do fluxo de atendimento</li>
                <li>Melhor aproveitamento do tráfego recebido</li>
              </ul>
            </article>
          </div>
        </div>
      </section>

      <section class="section section-muted" id="diferenciais">
        <div class="container">
          <div class="section-heading narrow">
            <p class="eyebrow">Diferenciais</p>
            <h2>Uma base digital simples, rápida e feita para gerar conversa</h2>
          </div>

          <div class="advantages-list">
            <article class="advantage-item">
              <h3>Mensagem organizada</h3>
              <p>
                A homepage parte de uma estrutura clara para destacar serviço,
                benefício e próxima ação sem excesso de elementos.
              </p>
            </article>
            <article class="advantage-item">
              <h3>Visual profissional</h3>
              <p>
                Design clean, responsivo e com hierarquia forte para transmitir
                confiança desde a primeira visita.
              </p>
            </article>
            <article class="advantage-item">
              <h3>Automação útil</h3>
              <p>
                O chatbot entra como apoio para qualificar contatos e reduzir o
                tempo entre interesse e atendimento.
              </p>
            </article>
          </div>
        </div>
      </section>

      <section class="section" id="processo">
        <div class="container process-layout">
          <div class="section-heading process-copy">
            <p class="eyebrow">Como funciona</p>
            <h2>Do posicionamento da oferta ao atendimento automatizado</h2>
            <p>
              Um fluxo simples para transformar a presença digital em uma operação
              mais clara e funcional.
            </p>
          </div>

          <div class="process-steps">
            <article class="process-step">
              <span>1</span>
              <div>
                <h3>Entendimento da necessidade</h3>
                <p>Mapeamento do serviço, público e objetivo principal da página.</p>
              </div>
            </article>
            <article class="process-step">
              <span>2</span>
              <div>
                <h3>Estrutura da landing page</h3>
                <p>Organização do conteúdo para apresentar melhor a proposta comercial.</p>
              </div>
            </article>
            <article class="process-step">
              <span>3</span>
              <div>
                <h3>Configuração do atendimento</h3>
                <p>Definição do fluxo inicial do chatbot para captar e encaminhar contatos.</p>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section class="section cta-section" id="contato">
        <div class="container cta-layout">
          <div class="cta-copy">
            <p class="eyebrow">Orçamento</p>
            <h2>Solicite um orçamento</h2>
            <p>
                Fazemos landing pages, e instalação de chatbots.
            </p>
          </div>

          <form class="contact-card" id="contact-form">
            <label>
              Nome
              <input type="text" name="nome" placeholder="Seu nome" required />
            </label>
            <label>
              Empresa
              <input type="text" name="empresa" placeholder="Nome da empresa" required />
            </label>
            <label>
              Objetivo
              <textarea
                name="objetivo"
                rows="4"
                placeholder="Ex.: criar uma landing page e organizar o primeiro atendimento"
                required
              ></textarea>
            </label>
            <button class="button button-primary button-block" type="submit">
              Enviar
            </button>
            <p class="form-note" id="form-feedback" aria-live="polite">
              Esta base inicial pode ser conectada depois ao canal de atendimento da sua escolha.
            </p>
          </form>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-wrapper">
        <div class="footer-brand">
          <p class="footer-title">
            <img id="logo-header" src="/assets/img/logo-1.webp" alt="Logo da smweb">
          </p>
          <p class="footer-copy">
            Landing pages e instalação de chatbots para apresentar melhor sua
            oferta e responder mais rápido.
          </p>
        </div>

        <div class="footer-socials" aria-label="Redes sociais e contato">
          <a
            class="social-link"
            href="https://www.instagram.com/digital_smweb"
            target="_blank"
            rel="noreferrer"
            aria-label="Instagram da smweb"
          >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678c-3.405 0-6.162 2.76-6.162 6.162 0 3.405 2.76 6.162 6.162 6.162 3.405 0 6.162-2.76 6.162-6.162 0-3.405-2.76-6.162-6.162-6.162zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405c0 .795-.646 1.44-1.44 1.44-.795 0-1.44-.646-1.44-1.44 0-.794.646-1.439 1.44-1.439.793-.001 1.44.645 1.44 1.439z"
              fill-rule="evenodd"
            />
          </svg>
            <span>Instagram</span>
          </a>

          <a
            class="social-link"
            href="mailto:contato@smweb.com.br"
            aria-label="Email da smweb"
          >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M1.5 8.6691V17.25C1.5 18.9069 2.84315 20.25 4.5 20.25H19.5C21.1569 20.25 22.5 18.9069 22.5 17.25V8.6691L13.5723 14.1631C12.6081 14.7564 11.3919 14.7564 10.4277 14.1631L1.5 8.6691Z"
            />
            <path
              d="M22.5 6.90783V6.75C22.5 5.09315 21.1569 3.75 19.5 3.75H4.5C2.84315 3.75 1.5 5.09315 1.5 6.75V6.90783L11.2139 12.8856C11.696 13.1823 12.304 13.1823 12.7861 12.8856L22.5 6.90783Z"
            />
          </svg>
            <span>Email</span>
          </a>

          <a
            class="social-link"
            href="https://wa.me/5500000000000"
            target="_blank"
            rel="noreferrer"
            aria-label="WhatsApp da smweb"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
              />
            </svg>
            <span>WhatsApp</span>
          </a>
        </div>

        <p class="footer-legal">
          &copy; <span id="current-year"></span> Todos os direitos reservados.
        </p>
      </div>
    </footer>

    <script src="/js/main.js"></script>
  </body>
</html>
